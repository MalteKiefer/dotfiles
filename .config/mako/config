# mako — Wayland notification daemon (Catppuccin Mocha)
max-history=5
markup=1
actions=1
history=1
default-timeout=5000
sort=+time
on-button-left=invoke-default-action
on-button-middle=dismiss-group
on-button-right=dismiss
on-touch=invoke-default-action

font=JetBrainsMono Nerd Font 11
background-color=#1E1E2Eee
text-color=#CDD6F4
border-color=#89B4FA
border-size=2
border-radius=10

width=320
height=240
margin=10
outer-margin=0
padding=14
icons=1
max-icon-size=48
icon-location=left
icon-path=/usr/share/icons/Papirus-Dark

format=<b>%s</b>\n%b
text-alignment=left
max-visible=5
layer=overlay
anchor=top-right
ignore-timeout=0

[urgency=low]
border-color=#A6ADC8
default-timeout=4000

[urgency=normal]
border-color=#89B4FA

[urgency=critical]
border-color=#F38BA8
background-color=#1E1E2Eee
text-color=#F38BA8
default-timeout=0

