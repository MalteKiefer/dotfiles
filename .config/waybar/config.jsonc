{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "height": 36,
  "spacing": 6,
  "margin-top": 4,
  "margin-left": 8,
  "margin-right": 8,
  "include": ["~/.config/waybar/modules.json"],

  "modules-left":   ["custom/menu", "niri/workspaces", "wlr/taskbar"],
  "modules-center": ["clock", "mpris"],
  "modules-right": [
    "privacy",
    "custom/mullvad",
    "idle_inhibitor",
    "network",
    "bluetooth",
    "pulseaudio#microphone",
    "pulseaudio",
    "backlight",
    "power-profiles-daemon",
    "battery",
    "custom/load",
    "tray",
    "custom/power"
  ]
}
