{
  "custom/menu": {
    "format": "<span size='14pt'>蟀</span>",
    "tooltip": false,
    "on-click": "rofi -show drun",
    "on-click-right": "rofi -show window"
  },

  "niri/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "default": "蟀劙",
      "active":  "蟀劘"
    }
  },

  "cpu": {
    "interval": 2,
    "format": "  {usage}%",
    "tooltip": true,
    "tooltip-format": "CPU {avg_frequency} GHz",
    "on-click": "alacritty -e btop"
  },

  "memory": {
    "interval": 5,
    "format": "  {percentage}%",
    "tooltip-format": "RAM: {used:0.1f} / {total:0.1f} GiB"
  },

  "clock": {
    "interval": 1,
    "format": "  {:%a %d.%m. %H:%M}",
    "format-alt": "{:%Y-%m-%d %H:%M:%S}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "left",
      "format": {
        "months": "<span color='#cdd6f4'><b>{}</b></span>",
        "days":   "<span color='#bac2de'>{}</span>",
        "weeks":  "<span color='#74c7ec'>W{}</span>",
        "today":  "<span color='#f38ba8'><b>{}</b></span>"
      }
    }
  },

  "mpris": {
    "format": "<span size='13pt'>蟀悗</span> {title}",
    "format-paused": "<span size='13pt'>蟀彜</span> {title}",
    "max-length": 36,
    "interval": 1,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "tooltip": true,
    "tooltip-format": "{title}\n{artist}"
  },

  "privacy": {
    "icon-size": 14,
    "transition-duration": 250,
    "modules": [
      { "type": "screenshare", "tooltip": false }
    ]
  },

  "tray": { "spacing": 8, "icon-size": 16 },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": { "activated": "蟀垐", "deactivated": "蟀垑" }
  },

  "network": {
    "format-wifi": "  {essid}",
    "format-ethernet": "蟀垁  {ifname}",
    "format-disconnected": "蟀き",
    "format-disabled": "蟀き",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
    "tooltip-format-ethernet": "{ifname}: {ipaddr}",
    "on-click": "alacritty -e nmtui",
    "interval": 5,
    "max-length": 18
  },

  "bluetooth": {
    "format-on": "蟀偗",
    "format-off": "蟀偛",
    "format-disabled": "蟀偛",
    "format-connected": "蟀偙 {device_alias}",
    "tooltip-format": "{controller_alias}\n{num_connections} connected",
    "on-click": "alacritty -e bluetuith",
    "max-length": 18
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "蟀潫",
    "format-icons": {
      "headphone": "",
      "default": ["蟀暱", "蟀杸", "蟀暰"]
    },
    "scroll-step": 5,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },

  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "蟀崿",
    "format-source-muted": "蟀嵀",
    "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-click-right": "pavucontrol -t 4",
    "tooltip-format": "Mic {volume}%"
  },

  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{icon}  {percent}%",
    "format-icons": ["蟀優", "蟀儫", "蟀儬"],
    "scroll-step": 5,
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Profile: {profile}\nDriver: {driver}",
    "format-icons": {
      "default": "",
      "performance": "蟀搮",
      "balanced":    "蟀緟",
      "power-saver": "蟀締"
    }
  },

  "battery": {
    "interval": 30,
    "states": { "warning": 25, "critical": 10 },
    "format": "{icon}  {capacity}%",
    "format-charging": "蟀倓  {capacity}%",
    "format-plugged": "蟀殽  {capacity}%",
    "format-icons": ["蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖"],
    "tooltip-format": "{timeTo}\n{power} W"
  },

  "custom/mullvad": {
    "exec": "/home/pr0ph37/.local/bin/mullvad-waybar",
    "return-type": "json",
    "interval": 5,
    "on-click": "sh -c 'mullvad status | head -1 | grep -q Connected && mullvad disconnect || mullvad connect'",
    "on-click-right": "mullvad-gui"
  },

  "custom/power": {
    "format": "<span size='13pt'>蟀惀</span>",
    "tooltip": false,
    "on-click": "wlogout || systemctl poweroff"
  }
}
