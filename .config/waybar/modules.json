{
  "custom/menu": {
    "format": "<span size='14pt'>σΑΘ΅</span>",
    "tooltip": false,
    "on-click": "rofi -show drun",
    "on-click-right": "rofi -show window"
  },

  "niri/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "default": "σΑ³Α",
      "active":  "σΑ³·"
    }
  },

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [],
    "all-outputs": true
  },

  "clock": {
    "interval": 1,
    "format": "  {:%a %d.%m. %H:%M}",
    "format-alt": "{:%Y-%m-%d %H:%M:%S}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "left",
      "format": {
        "months": "<span color='#cdd6f4'><b>{}</b></span>",
        "days":   "<span color='#bac2de'>{}</span>",
        "weeks":  "<span color='#74c7ec'>W{}</span>",
        "today":  "<span color='#f38ba8'><b>{}</b></span>"
      }
    }
  },

  "mpris": {
    "format": "<span size='13pt'>σΑêé</span> {title}",
    "format-paused": "<span size='13pt'>σΑèΛ</span> {title}",
    "max-length": 36,
    "interval": 1,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "tooltip": true,
    "tooltip-format": "{title}\n{artist}"
  },

  "privacy": {
    "icon-size": 14,
    "transition-duration": 250,
    "modules": [
      { "type": "screenshare", "tooltip": false }
    ]
  },

  "tray": { "spacing": 8, "icon-size": 16 },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": { "activated": "σΑàà", "deactivated": "σΑàâ" }
  },

  "network": {
    "format-wifi": "{icon}",
    "format-ethernet": "σΑàÄ",
    "format-disconnected": "σΑΛ°",
    "format-disabled": "σΑΛ°",
    "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"],
    "tooltip-format-wifi": "{essid}\nSignal: {signalStrength}%\n{ipaddr}",
    "tooltip-format-ethernet": "{ifname}: {ipaddr}",
    "tooltip-format-disconnected": "Nicht verbunden",
    "on-click": "alacritty -e nmtui",
    "interval": 5
  },

  "bluetooth": {
    "format": "σΑ²·",
    "format-on": "σΑ²·",
    "format-off": "σΑ²≤",
    "format-disabled": "σΑ²≤",
    "format-connected": "σΑ²±",
    "tooltip-format": "{controller_alias}\n{status}",
    "tooltip-format-connected": "{controller_alias}\n{num_connections} verbunden\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "on-click": "alacritty -e bluetuith"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "σΑùü",
    "format-icons": {
      "headphone": "",
      "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
    },
    "scroll-step": 5,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },

  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "σΑç§",
    "format-source-muted": "σΑç≠",
    "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-click-right": "pavucontrol -t 4",
    "tooltip-format": "Mic {volume}%"
  },

  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{icon}  {percent}%",
    "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
    "scroll-step": 5,
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Profile: {profile}\nDriver: {driver}",
    "format-icons": {
      "default": "",
      "performance": "σΑ™Ö",
      "balanced":    "σΑΨÖ",
      "power-saver": "σΑΨÜ"
    }
  },

  "battery": {
    "interval": 30,
    "states": { "warning": 25, "critical": 10 },
    "format": "{icon}  {capacity}%",
    "format-charging": "σΑ²³  {capacity}%",
    "format-plugged": "σΑöΞ  {capacity}%",
    "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
    "tooltip-format": "{timeTo}\n{power} W"
  },

  "custom/load": {
    "format": "σΑ™Ö {}",
    "exec": "/home/pr0ph37/.local/bin/load-waybar",
    "return-type": "json",
    "interval": 3,
    "on-click": "alacritty -e btop"
  },

  "custom/mullvad": {
    "exec": "/home/pr0ph37/.local/bin/mullvad-waybar",
    "return-type": "json",
    "interval": 5,
    "on-click": "sh -c 'mullvad status | head -1 | grep -q Connected && mullvad disconnect || mullvad connect'",
    "on-click-right": "mullvad-gui"
  },

  "custom/power": {
    "format": "<span size='13pt'>σΑêΞ</span>",
    "tooltip": false,
    "on-click": "wlogout || systemctl poweroff"
  }
}
