#!/bin/sh
# waybar custom module: mullvad status (JSON)

status_out=$(mullvad status 2>/dev/null)
state=$(printf '%s\n' "$status_out" | head -n1 | awk '{print $1}')
loc=$(printf '%s\n' "$status_out" | sed -n 's/.*Visible location:[[:space:]]*//p' | sed 's/\. IPv4.*$//')
country=$(printf '%s\n' "$loc" | cut -d',' -f1 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
city=$(printf '%s\n' "$loc" | cut -d',' -f2 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

flag_for() {
  case "$1" in
    Germany) echo "🇩🇪" ;;
    Austria) echo "🇦🇹" ;;
    Switzerland) echo "🇨🇭" ;;
    France) echo "🇫🇷" ;;
    Netherlands) echo "🇳🇱" ;;
    Sweden) echo "🇸🇪" ;;
    Norway) echo "🇳🇴" ;;
    Finland) echo "🇫🇮" ;;
    Denmark) echo "🇩🇰" ;;
    "United Kingdom"|UK) echo "🇬🇧" ;;
    Ireland) echo "🇮🇪" ;;
    Belgium) echo "🇧🇪" ;;
    Spain) echo "🇪🇸" ;;
    Portugal) echo "🇵🇹" ;;
    Italy) echo "🇮🇹" ;;
    Poland) echo "🇵🇱" ;;
    "Czech Republic"|Czechia) echo "🇨🇿" ;;
    "United States"|USA) echo "🇺🇸" ;;
    Canada) echo "🇨🇦" ;;
    Japan) echo "🇯🇵" ;;
    Singapore) echo "🇸🇬" ;;
    Australia) echo "🇦🇺" ;;
    *) echo "🌐" ;;
  esac
}

esc() { printf '%s' "$1" | sed 's/"/\\"/g; s/\\/\\\\/g'; }

case "$state" in
  Connected)
    flag=$(flag_for "$country")
    text="$flag $country"
    tooltip="Mullvad: $loc"
    class="connected"
    ;;
  Connecting|Disconnecting)
    text="… $state"
    tooltip="Mullvad $state"
    class="connecting"
    ;;
  *)
    text=" off"
    tooltip="Mullvad disconnected ($country)"
    class="disconnected"
    ;;
esac

printf '{"text":"%s","tooltip":"%s","class":"%s","alt":"%s"}\n' \
  "$(esc "$text")" "$(esc "$tooltip")" "$class" "$state"
